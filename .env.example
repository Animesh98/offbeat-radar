# Required: LLM
ANTHROPIC_API_KEY=sk-ant-...

# Required: pick ONE Reddit backend (or both — OAuth wins).
# Option A — Reddit Data API (free; needs reddit.com/prefs/apps "script" app)
REDDIT_CLIENT_ID=
REDDIT_CLIENT_SECRET=
REDDIT_USERNAME=
REDDIT_PASSWORD=
# REDDIT_USER_AGENT=offbeat-radar/1.0 (by /u/your-username)

# Option B — Apify Reddit Scraper (paid; ~$5/mo at default volume)
APIFY_TOKEN=

# Required: Gmail SMTP for digest delivery
# Use https://myaccount.google.com/apppasswords (NOT your normal password)
GMAIL_APP_PASSWORD=
GMAIL_FROM=you@gmail.com

# Optional: send the digest to a different address
# OFFBEAT_DIGEST_TO=other@gmail.com

# Optional: load secrets from extra files (colon-separated paths)
# OFFBEAT_EXTRA_ENV_FILES=/path/to/shared/.env:/another/.env

# Optional: dashboard URL used for Skip links in the email (only useful
# if you've wired the offbeat scraper into your own dashboard).
# OFFBEAT_DASHBOARD_URL=http://localhost:8001
