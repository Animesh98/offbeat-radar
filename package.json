{
  "name": "offbeat-radar",
  "version": "0.1.0",
  "description": "Personal job-search digest — polls Reddit + HN for fresh hiring posts, LLM-classifies them, and emails delta digests.",
  "type": "module",
  "private": true,
  "scripts": {
    "fetch": "node offbeat-fetch.mjs",
    "digest": "node offbeat-digest.mjs",
    "dry": "node offbeat-fetch.mjs --dry --verbose --limit=5"
  },
  "dependencies": {
    "better-sqlite3": "^12.4.1",
    "dotenv": "^17.4.1",
    "js-yaml": "^4.1.1",
    "nodemailer": "^7.0.13"
  },
  "engines": {
    "node": ">=18"
  },
  "license": "MIT",
  "author": "Animesh Sinha",
  "repository": {
    "type": "git",
    "url": "https://github.com/Animesh98/offbeat-radar.git"
  }
}
